# Environment variables for CoreInventory backend
# Copy this file to .env and fill in production values

APP_NAME=CoreInventory
APP_VERSION=1.0.0
DEBUG=True

# PostgreSQL connection string (Neon DB - async driver)
# Replace with your own Neon DB connection string
DATABASE_URL=YOUR-DB-KEY
DATABASE_ECHO=False

# JWT
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated is not supported; modify in config.py for multiple)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
